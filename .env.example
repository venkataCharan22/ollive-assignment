# ============================================================
# Ollive Assignment — environment variables
# Copy to .env at repo root. Docker Compose reads from here.
# ============================================================

# ---- Postgres (ingestion service stores chat + log data here)
POSTGRES_USER=ollive
POSTGRES_PASSWORD=ollive
POSTGRES_DB=ollive
DATABASE_URL=postgresql://ollive:ollive@postgres:5432/ollive?schema=public

# ---- Redis (event bus — Redis Streams)
REDIS_URL=redis://redis:6379

# ---- Ingestion service
INGESTION_PORT=4000
# Shared secret the SDK sends in X-Ollive-Key.
# Rotate in production; this is a demo value.
INGESTION_API_KEY=dev-ingest-key-change-me

# ---- Chatbot (Next.js)
CHATBOT_PORT=3000
# Where the chatbot's Next.js server reaches the ingestion API.
# Inside Docker: http://ingestion:4000. Outside: http://localhost:4000.
INGESTION_URL=http://ingestion:4000
NEXT_PUBLIC_INGESTION_URL=http://localhost:4000

# ---- LLM providers
# Set whichever keys you have. The chatbot UI lets you pick a model;
# providers without a key are disabled at runtime.
# If none are set, the mock provider is used (canned streaming output).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Groq (the inference platform — Llama / Mixtral / Gemma at very low latency).
# Get a key from console.groq.com. Keys start with `gsk_`.
GROQ_API_KEY=

# ---- Behaviour flags
# Enable PII redaction in the SDK and worker (true | false)
PII_REDACTION=true
# Default provider when chatbot starts (openai | anthropic | google | mock)
DEFAULT_PROVIDER=mock
# Default model id for the default provider
DEFAULT_MODEL=mock-fast
